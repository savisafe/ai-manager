PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_manager?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379

WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=change-me
WHATSAPP_PHONE_NUMBER_ID=change-me
WHATSAPP_APP_SECRET=change-me

TELEGRAM_BOT_TOKEN=твой_токен_от_BotFather
TELEGRAM_WEBHOOK_URL=https://твой-ngrok.ngrok-free.app/webhooks/telegram

LLM_ENABLED=true
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=llama3:latest
LLM_API_KEY=ollama
# Ниже 0.5 — меньше «фантазий» и уходов в сторону (для строгой темы попробуй 0.25–0.4)
LLM_TEMPERATURE=0.35
# Ограничение длины ответа (токены). Пусто = по умолчанию провайдера
LLM_MAX_TOKENS=400

# Рамка темы: одно-два предложения, чем конкретнее — тему лучше держит модель
LLM_TOPIC=Консультации и продажи только по [название продукта/услуги]. Не обсуждать другие продукты и хобби-чаты.
# Через запятую или | — темы/типы вопросов, на которые не отвечать
LLM_FORBIDDEN_TOPICS=политика,религия,медицинские диагнозы,юридические заключения,криптоинвестиции
# Опционально: путь к txt/md с фактами о продукте и запретами (относительно корня проекта)
# LLM_SCOPE_FILE=config/llm-scope.txt

COMPANY_NAME=Название твоей компании